# ─────────────────────────────────────────────────────────────────────────────
# DeepLinkOS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site URL (used in sitemap, OG tags, canonical links) ─────────────────────
NEXT_PUBLIC_SITE_URL=https://deeplinkos.com

# ── Resend (transactional email) ──────────────────────────────────────────────
# Get your free API key at: https://resend.com
# Free tier: 100 emails/day, no credit card required.
# 1. Sign up at resend.com
# 2. Create an API key (Resend dashboard → API Keys → Add API Key)
# 3. Paste it below
RESEND_API_KEY=re_hA4A3rUi_BN6w5ZEofZpsQkaib4ZsuDQg

# The "From" address shown in the email client.
# Must match a verified domain in Resend (or use onboarding@resend.dev for testing).
RESEND_FROM=DeepLinkOS <noreply@deeplinkos.com>

# Where contact form submissions are delivered.
CONTACT_EMAIL=contact@deeplinkos.com

# ── Phase 3: Supabase ─────────────────────────────────────────────────────────
# Self-hosted on Coolify at your VPS.
# Uncomment and fill in when Phase 3 begins.
# NEXT_PUBLIC_SUPABASE_URL=https://your-supabase.deeplinkos.com
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Phase 3: Google OAuth ─────────────────────────────────────────────────────
# Uncomment when setting up Google One Tap auth.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
